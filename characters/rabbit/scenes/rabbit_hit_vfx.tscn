[gd_scene format=3 uid="uid://c1lnjufs7jp1c"]

[sub_resource type="GDScript" id="GDScript_2ncg2"]
script/source = "extends Node2D

@export var color: Color = Color(1.0, 0.4, 0.7) # Pink
@export var duration: float = 0.5

var _time: float = 0.0
var _phase: int = 0 # 0: Star, 1: Burst+Rabbit, 2: Dissipate

func _ready() -> void:
	# Self destruct after animation
	await get_tree().create_timer(duration).timeout
	queue_free()

func _process(delta: float) -> void:
	_time += delta
	queue_redraw()

func _draw() -> void:
	var center = Vector2.ZERO
	var t = _time / duration
	
	if t < 0.2:
		# Phase 1: Star (Spiky 4-point)
		var size = 40.0 * (t / 0.2)
		var points = PackedVector2Array([
			Vector2(0, -size), Vector2(size * 0.2, -size * 0.2),
			Vector2(size, 0), Vector2(size * 0.2, size * 0.2),
			Vector2(0, size), Vector2(-size * 0.2, size * 0.2),
			Vector2(-size, 0), Vector2(-size * 0.2, -size * 0.2)
		])
		draw_colored_polygon(points, color)
		draw_polyline(points, Color.WHITE, 2.0, true) # White outline
		
	elif t < 0.5:
		# Phase 2: Burst + Rabbit Silhouette
		var size = 50.0
		# Draw Burst (Jagged circle)
		var burst_points = PackedVector2Array()
		var num_points = 12
		for i in range(num_points):
			var angle = i * (TAU / num_points)
			var r = size if i % 2 == 0 else size * 0.5
			burst_points.append(Vector2(cos(angle), sin(angle)) * r)
		draw_colored_polygon(burst_points, color)
		
		# Draw Rabbit Head Silhouette (White)
		draw_circle(center, 15.0, Color.WHITE)
		# Ears
		draw_circle(center + Vector2(-8, -20), 5.0, Color.WHITE) # Left ear base
		draw_circle(center + Vector2(8, -20), 5.0, Color.WHITE) # Right ear base
		draw_line(center + Vector2(-8, -15), center + Vector2(-12, -35), Color.WHITE, 6.0) # Left ear
		draw_line(center + Vector2(8, -15), center + Vector2(12, -35), Color.WHITE, 6.0) # Right ear
		
		# Eyes (Pink)
		draw_circle(center + Vector2(-5, 5), 2.0, color)
		draw_circle(center + Vector2(5, 5), 2.0, color)
		
	else:
		# Phase 3: Dissipate (Particles handled by CPUParticles2D, here just fade out burst)
		pass
"

