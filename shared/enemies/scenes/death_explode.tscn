[sub_resource type="GDScript" id="GDScript_kbafv"]
script/source = "extends Node2D

@onready var sprite: Sprite2D = $Sprite2D
@onready var animation_player: AnimationPlayer = $AnimationPlayer


func _ready() -> void:
	var anim_length = 0.8
	
	if animation_player.has_animation(\"explode\"):
		animation_player.play(\"explode\")
		anim_length = animation_player.get_animation(\"explode\").length
	else:
		# Fallback if animation missing
		get_tree().create_timer(0.5).timeout.connect(func(): _on_animation_finished(\"\"))
		anim_length = 0.5

	# Setup the jump and fall tween
	var tween = create_tween()
	var start_y = position.y
	var jump_height = 80.0
	var half_time = anim_length / 2.0
	
	# Float up
	tween.tween_property(self, \"position:y\", start_y - jump_height, half_time).set_trans(Tween.TRANS_QUAD).set_ease(Tween.EASE_OUT)
	# Fall down to original ground position
	tween.tween_property(self, \"position:y\", start_y, half_time).set_trans(Tween.TRANS_QUAD).set_ease(Tween.EASE_IN)

func _on_animation_finished(_anim_name: String) -> void:
	pass
"

